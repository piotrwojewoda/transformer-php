{% extends 'base.html.twig' %}

{% block title %}Ingest corpus{% endblock %}

{% block body %}
    <h1 class="text-2xl font-bold mb-6">Ingest a new corpus</h1>

    {{ form_start(form, {'attr': {'class': 'space-y-4 bg-white p-6 rounded shadow'}}) }}
        {{ form_row(form.name, {'label': 'Corpus name'}) }}
        {{ form_row(form.text, {'label': 'Text content'}) }}
        <div>
            {{ form_widget(form.save, {'attr': {'class': 'px-4 py-2 bg-blue-600 text-white rounded'}}) }}
        </div>
    {{ form_end(form) }}
{% endblock %}
