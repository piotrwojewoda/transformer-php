{% extends 'base.html.twig' %}

{% block title %}{{ 'page.corpora'|trans }} — Transformer PHP{% endblock %}

{% block body %}
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold">{{ 'page.corpora'|trans }}</h1>
        <a href="{{ path('corpus_new') }}" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 font-medium">{{ 'action.ingest_corpus'|trans }}</a>
    </div>

    {% if corpora is empty %}
        <p class="text-gray-600">{{ 'empty.corpora'|trans }}</p>
    {% else %}
        <div class="bg-white shadow rounded-lg">
            <table class="w-full text-sm">
                <thead class="text-left border-b border-gray-200 bg-gray-50">
                    <tr><th class="p-3 text-gray-600">{{ 'table.name'|trans }}</th><th class="p-3 text-gray-600">{{ 'corpus.characters'|trans }}</th><th class="p-3"></th></tr>
                </thead>
                <tbody>
                {% for corpus in corpora %}
                    <tr class="border-b border-gray-100 hover:bg-gray-50">
                        <td class="p-3 font-medium">{{ corpus.name }}</td>
                        <td class="p-3">{{ corpus.length() }}</td>
                        <td class="p-3"><a href="{{ path('corpus_show', {id: corpus.id.value}) }}" class="text-blue-600 hover:text-blue-800">{{ 'action.view'|trans }}</a></td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
