{% extends 'base.html.twig' %}

{% block title %}{{ 'page.dashboard'|trans }} — Transformer PHP{% endblock %}

{% block body %}
    <h1 class="text-3xl font-bold mb-6">{{ 'page.dashboard'|trans }}</h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
        <a href="{{ path('corpus_list') }}" class="block bg-white p-6 rounded-lg shadow hover:shadow-md hover:bg-blue-50 transition">
            <div class="text-sm text-gray-500">{{ 'stat.corpora'|trans }}</div>
            <div class="text-3xl font-bold text-blue-600">{{ corpusCount }}</div>
        </a>
        <a href="{{ path('model_list') }}" class="block bg-white p-6 rounded-lg shadow hover:shadow-md hover:bg-blue-50 transition">
            <div class="text-sm text-gray-500">{{ 'stat.models'|trans }}</div>
            <div class="text-3xl font-bold text-blue-600">{{ modelCount }}</div>
        </a>
        <a href="{{ path('prediction_list') }}" class="block bg-white p-6 rounded-lg shadow hover:shadow-md hover:bg-blue-50 transition">
            <div class="text-sm text-gray-500">{{ 'stat.predictions'|trans }}</div>
            <div class="text-3xl font-bold text-blue-600">{{ predictionCount }}</div>
        </a>
    </div>

    <div class="bg-white p-6 rounded-lg shadow">
        <h2 class="text-xl font-semibold mb-4 text-gray-800">{{ 'section.quick_actions'|trans }}</h2>
        <ul class="space-y-3 text-sm">
            <li><a href="{{ path('corpus_new') }}" class="text-blue-600 hover:text-blue-800 hover:underline">{{ 'action.ingest_corpus'|trans }}</a></li>
            <li><a href="{{ path('model_new') }}" class="text-blue-600 hover:text-blue-800 hover:underline">{{ 'action.create_model'|trans }}</a></li>
            <li><a href="{{ path('model_list') }}" class="text-blue-600 hover:text-blue-800 hover:underline">{{ 'action.list_models'|trans }}</a></li>
        </ul>
    </div>
{% endblock %}
