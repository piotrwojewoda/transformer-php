{% extends 'base.html.twig' %}

{% block title %}New model{% endblock %}

{% block body %}
    <h1 class="text-2xl font-bold mb-6">Create a new model</h1>

    {{ form_start(form, {'attr': {'class': 'space-y-4 bg-white p-6 rounded shadow'}}) }}
        {{ form_row(form.name) }}
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            {{ form_row(form.dModel) }}
            {{ form_row(form.numHeads) }}
            {{ form_row(form.numLayers) }}
            {{ form_row(form.dFf) }}
            {{ form_row(form.maxSeqLen) }}
            {{ form_row(form.vocabSize) }}
        </div>
        <h2 class="text-lg font-semibold pt-4 border-t">Training</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {{ form_row(form.learningRate) }}
            {{ form_row(form.totalEpochs) }}
            {{ form_row(form.seqLen) }}
        </div>
        <div>
            {{ form_widget(form.save, {'attr': {'class': 'px-4 py-2 bg-blue-600 text-white rounded'}}) }}
        </div>
    {{ form_end(form) }}
{% endblock %}
