{% extends 'base.html.twig' %}

{% block title %}{{ 'page.new_model'|trans }}{% endblock %}

{% block body %}
    <h1 class="text-2xl font-bold mb-6">{{ 'page.new_model'|trans }}</h1>

    {{ form_start(form, {'attr': {'class': 'space-y-6 bg-white p-6 rounded-lg shadow'}}) }}
        <div class="mb-4">
            {{ form_label(form.name, 'form.label.name'|trans, {'tooltip': 'tooltip.name'}) }}
            {{ form_widget(form.name, {'attr': {'class': 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border'}}) }}
            {{ form_errors(form.name) }}
        </div>
        <h2 class="text-lg font-semibold pt-4 border-t text-gray-800">{{ 'page.new_model'|trans }}</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            <div class="mb-4">
                {{ form_label(form.dModel, 'form.label.d_model'|trans, {'tooltip': 'tooltip.d_model'}) }}
                {{ form_widget(form.dModel, {'attr': {'class': 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border'}}) }}
                {{ form_errors(form.dModel) }}
            </div>
            <div class="mb-4">
                {{ form_label(form.numHeads, 'form.label.num_heads'|trans, {'tooltip': 'tooltip.num_heads'}) }}
                {{ form_widget(form.numHeads, {'attr': {'class': 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border'}}) }}
                {{ form_errors(form.numHeads) }}
            </div>
            <div class="mb-4">
                {{ form_label(form.numLayers, 'form.label.num_layers'|trans, {'tooltip': 'tooltip.num_layers'}) }}
                {{ form_widget(form.numLayers, {'attr': {'class': 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border'}}) }}
                {{ form_errors(form.numLayers) }}
            </div>
            <div class="mb-4">
                {{ form_label(form.dFf, 'form.label.d_ff'|trans, {'tooltip': 'tooltip.d_ff'}) }}
                {{ form_widget(form.dFf, {'attr': {'class': 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border'}}) }}
                {{ form_errors(form.dFf) }}
            </div>
            <div class="mb-4">
                {{ form_label(form.maxSeqLen, 'form.label.max_seq_len'|trans, {'tooltip': 'tooltip.max_seq_len'}) }}
                {{ form_widget(form.maxSeqLen, {'attr': {'class': 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border'}}) }}
                {{ form_errors(form.maxSeqLen) }}
            </div>
            <div class="mb-4">
                {{ form_label(form.vocabSize, 'form.label.vocab_size'|trans, {'tooltip': 'tooltip.vocab_size'}) }}
                {{ form_widget(form.vocabSize, {'attr': {'class': 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border'}}) }}
                {{ form_errors(form.vocabSize) }}
            </div>
        </div>
        <h2 class="text-lg font-semibold pt-4 border-t text-gray-800">{{ 'training.heading'|trans }}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="mb-4">
                {{ form_label(form.learningRate, 'form.label.learning_rate'|trans, {'tooltip': 'tooltip.learning_rate'}) }}
                {{ form_widget(form.learningRate, {'attr': {'class': 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border'}}) }}
                {{ form_errors(form.learningRate) }}
            </div>
            <div class="mb-4">
                {{ form_label(form.totalEpochs, 'form.label.total_epochs'|trans, {'tooltip': 'tooltip.total_epochs'}) }}
                {{ form_widget(form.totalEpochs, {'attr': {'class': 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border'}}) }}
                {{ form_errors(form.totalEpochs) }}
            </div>
            <div class="mb-4">
                {{ form_label(form.seqLen, 'form.label.seq_len'|trans, {'tooltip': 'tooltip.seq_len'}) }}
                {{ form_widget(form.seqLen, {'attr': {'class': 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border'}}) }}
                {{ form_errors(form.seqLen) }}
            </div>
        </div>
        <div class="pt-4">
            {{ form_widget(form.save, {'attr': {'class': 'w-full px-4 py-2.5 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 font-medium'}, 'label': 'form.save'|trans}) }}
        </div>
    {{ form_end(form) }}
{% endblock %}
