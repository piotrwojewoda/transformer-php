{% extends 'base.html.twig' %}

{% block title %}Models{% endblock %}

{% block body %}
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold">Models</h1>
        <a href="{{ path('model_new') }}" class="px-4 py-2 bg-blue-600 text-white rounded">+ New model</a>
    </div>

    {% if models is empty %}
        <p class="text-gray-600">No models yet. Create one to get started.</p>
    {% else %}
        <div class="bg-white shadow rounded">
            <table class="w-full text-sm">
                <thead class="text-left border-b">
                    <tr><th class="p-3">Name</th><th class="p-3">Status</th><th class="p-3">dModel</th><th class="p-3">Layers</th><th class="p-3">Last loss</th><th class="p-3"></th></tr>
                </thead>
                <tbody>
                {% for model in models %}
                    <tr class="border-b hover:bg-gray-50">
                        <td class="p-3 font-medium">{{ model.name }}</td>
                        <td class="p-3"><span class="px-2 py-1 rounded text-xs bg-gray-100">{{ model.status.value }}</span></td>
                        <td class="p-3">{{ model.dModel }}</td>
                        <td class="p-3">{{ model.numLayers }}</td>
                        <td class="p-3">{{ model.lastLoss is not null ? model.lastLoss|number_format(4) : '—' }}</td>
                        <td class="p-3"><a href="{{ path('model_show', {id: model.id}) }}" class="text-blue-600">View</a></td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
