{% extends 'base.html.twig' %}

{% block title %}{{ 'page.models'|trans }}{% endblock %}

{% block body %}
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold">{{ 'page.models'|trans }}</h1>
        <a href="{{ path('model_new') }}" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 font-medium">{{ 'action.new_model'|trans }}</a>
    </div>

    {% if models is empty %}
        <p class="text-gray-600">{{ 'empty.models'|trans }}</p>
    {% else %}
        <div class="bg-white shadow rounded-lg">
            <table class="w-full text-sm">
                <thead class="text-left border-b border-gray-200 bg-gray-50">
                    <tr><th class="p-3 text-gray-600">{{ 'table.name'|trans }}</th><th class="p-3 text-gray-600">{{ 'table.status'|trans }}</th><th class="p-3 text-gray-600">{{ 'table.dmodel'|trans }}</th><th class="p-3 text-gray-600">{{ 'table.layers'|trans }}</th><th class="p-3 text-gray-600">{{ 'table.last_loss'|trans }}</th><th class="p-3"></th></tr>
                </thead>
                <tbody>
                {% for model in models %}
                    <tr class="border-b border-gray-100 hover:bg-gray-50">
                        <td class="p-3 font-medium">{{ model.name }}</td>
                        <td class="p-3"><span class="px-2 py-1 rounded text-xs bg-gray-100 text-gray-700">{{ model.status.value }}</span></td>
                        <td class="p-3">{{ model.dModel }}</td>
                        <td class="p-3">{{ model.numLayers }}</td>
                        <td class="p-3">{{ model.lastLoss is not null ? model.lastLoss|number_format(4) : '—' }}</td>
                        <td class="p-3"><a href="{{ path('model_show', {id: model.id}) }}" class="text-blue-600 hover:text-blue-800">{{ 'action.view'|trans }}</a></td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
