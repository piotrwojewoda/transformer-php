{% extends 'base.html.twig' %}
{% import 'macros/tooltip.html.twig' as tooltip %}

{% block title %}{{ model.name }}{% endblock %}

{% block body %}
    <h1 class="text-2xl font-bold mb-2">{{ model.name }}</h1>
    <p class="text-sm text-gray-600 mb-6">{{ 'model.uuid'|trans }}: <code>{{ model.id }}</code> · {{ model.totalWeightRows() }} {{ 'model.weight_rows'|trans }}</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div class="bg-white p-6 rounded-lg shadow">
            <h2 class="text-lg font-semibold mb-4 text-gray-800">{{ 'section.configuration'|trans }}</h2>
            <dl class="text-sm space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-gray-100"><dt class="text-gray-600 flex items-center">{{ 'config.status'|trans }}{{ tooltip.icon('tooltip.status') }}</dt><dd><span class="px-2 py-1 rounded text-xs bg-gray-100">{{ model.status.value }}</span></dd></div>
                <div class="flex justify-between items-center py-2 border-b border-gray-100"><dt class="text-gray-600 flex items-center">{{ 'config.dmodel'|trans }}{{ tooltip.icon('tooltip.d_model') }}</dt><dd class="font-medium">{{ model.dModel }}</dd></div>
                <div class="flex justify-between items-center py-2 border-b border-gray-100"><dt class="text-gray-600 flex items-center">{{ 'config.num_heads'|trans }}{{ tooltip.icon('tooltip.num_heads') }}</dt><dd class="font-medium">{{ model.numHeads }}</dd></div>
                <div class="flex justify-between items-center py-2 border-b border-gray-100"><dt class="text-gray-600 flex items-center">{{ 'config.num_layers'|trans }}{{ tooltip.icon('tooltip.num_layers') }}</dt><dd class="font-medium">{{ model.numLayers }}</dd></div>
                <div class="flex justify-between items-center py-2 border-b border-gray-100"><dt class="text-gray-600 flex items-center">{{ 'config.dff'|trans }}{{ tooltip.icon('tooltip.d_ff') }}</dt><dd class="font-medium">{{ model.dFf }}</dd></div>
                <div class="flex justify-between items-center py-2 border-b border-gray-100"><dt class="text-gray-600 flex items-center">{{ 'config.max_seq_len'|trans }}{{ tooltip.icon('tooltip.max_seq_len') }}</dt><dd class="font-medium">{{ model.maxSeqLen }}</dd></div>
                <div class="flex justify-between items-center py-2"><dt class="text-gray-600 flex items-center">{{ 'config.vocab_size'|trans }}{{ tooltip.icon('tooltip.vocab_size') }}</dt><dd class="font-medium">{{ model.vocabSize }}</dd></div>
            </dl>
        </div>

        <div class="bg-white p-6 rounded-lg shadow">
            <h2 class="text-lg font-semibold mb-4 text-gray-800">{{ 'section.actions'|trans }}</h2>

            <div class="mb-4">
                <label for="training-category" class="block text-sm font-medium text-gray-700 mb-1 flex items-center">
                    {{ 'form.label.training_category'|trans }}{{ tooltip.icon('tooltip.training_category') }}
                </label>
                <select id="training-category" name="categoryId" class="w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border">
                    {% for category in categories %}
                        <option value="{{ category.id.value }}">{{ category.name }}</option>
                    {% endfor %}
                </select>
            </div>

            <form action="{{ path('model_train_one', {id: model.id}) }}" method="post" class="mb-3">
                <input type="hidden" name="categoryId" class="train-category-hidden" value="{{ categories|first ? categories|first.id.value : '' }}">
                <button type="submit" class="w-full px-4 py-2.5 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 font-medium flex items-center justify-center gap-2">
                    {{ 'action.train_1_epoch'|trans }}{{ tooltip.icon('tooltip.train_1_epoch') }}
                </button>
            </form>
            <form action="{{ path('model_train_n', {id: model.id}) }}" method="post" class="flex gap-2 items-center">
                <input type="hidden" name="categoryId" class="train-category-hidden" value="{{ categories|first ? categories|first.id.value : '' }}">
                {{ tooltip.icon('tooltip.train_n') }}
                <input type="number" name="n" min="1" max="500" value="10" class="flex-1 px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm">
                <button type="submit" class="px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 focus:ring-2 focus:ring-green-500 focus:ring-offset-2 font-medium flex items-center gap-1">
                    {{ 'action.train_n_epochs'|trans }}{{ tooltip.icon('tooltip.train_n') }}
                </button>
            </form>
            <a href="{{ path('prediction_new', {model: model.id}) }}" class="block mt-4 text-center px-4 py-2.5 bg-purple-600 text-white rounded-md hover:bg-purple-700 focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 font-medium flex items-center justify-center gap-2">
                {{ 'action.generate_prediction'|trans }}{{ tooltip.icon('tooltip.generate_prediction') }}
            </a>
        </div>
    </div>

    <div id="training-progress">
        {% include 'model/_training_progress.html.twig' %}
    </div>

    {% if history is not null and history.isLive %}
    <script>
        (function () {
            const container = document.getElementById('training-progress');
            if (!container) return;
            const url = '{{ path('model_training_progress', {id: model.id}) }}';
            const interval = setInterval(function () {
                fetch(url)
                    .then(function (r) { return r.text(); })
                    .then(function (html) {
                        container.innerHTML = html;
                        // Stop polling when the job is no longer live.
                        if (container.querySelector('[data-live="0"]')) {
                            clearInterval(interval);
                        }
                    })
                    .catch(function () { clearInterval(interval); });
            }, 2000);
        })();
    </script>
    <noscript>
        <meta http-equiv="refresh" content="2">
    </noscript>
    {% endif %}

    <script>
        (function () {
            const select = document.getElementById('training-category');
            const hiddenInputs = document.querySelectorAll('.train-category-hidden');
            if (!select) return;
            select.addEventListener('change', function () {
                hiddenInputs.forEach(function (input) {
                    input.value = select.value;
                });
            });
        })();
    </script>
{% endblock %}
