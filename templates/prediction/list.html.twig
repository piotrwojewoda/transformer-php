{% extends 'base.html.twig' %}

{% block title %}{{ 'page.predictions'|trans }} — Transformer PHP{% endblock %}

{% block body %}
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold">{{ 'page.predictions'|trans }}</h1>
        <a href="{{ path('prediction_new') }}" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 font-medium">{{ 'action.new_prediction'|trans }}</a>
    </div>

    {% if predictions is empty %}
        <p class="text-gray-600">{{ 'empty.predictions'|trans }}</p>
    {% else %}
        <div class="bg-white shadow rounded-lg">
            <table class="w-full text-sm">
                <thead class="text-left border-b border-gray-200 bg-gray-50">
                    <tr>
                        <th class="p-3 text-gray-600">{{ 'table.status'|trans }}</th>
                        <th class="p-3 text-gray-600">{{ 'label.model'|trans }}</th>
                        <th class="p-3 text-gray-600">{{ 'label.sampling'|trans }}</th>
                        <th class="p-3 text-gray-600">{{ 'label.prompt'|trans }}</th>
                        <th class="p-3"></th>
                    </tr>
                </thead>
                <tbody>
                {% for prediction in predictions %}
                    <tr class="border-b border-gray-100 hover:bg-gray-50">
                        <td class="p-3">
                            <span class="px-2 py-1 rounded text-xs
                                {{ prediction.status.value == 'done' ? 'bg-green-100 text-green-800' : '' }}
                                {{ prediction.status.value == 'failed' ? 'bg-red-100 text-red-800' : '' }}
                                {{ prediction.status.value in ['queued','running'] ? 'bg-yellow-100 text-yellow-800' : '' }}">
                                {{ prediction.status.value }}
                            </span>
                        </td>
                        <td class="p-3 font-mono text-xs">{{ prediction.modelId.value }}</td>
                        <td class="p-3">{{ prediction.sampling.strategy.value }} · {{ prediction.sampling.maxNewTokens }}{{ prediction.sampling.topK is not null ? ' · K=' ~ prediction.sampling.topK }}</td>
                        <td class="p-3 truncate max-w-xs" title="{{ prediction.prompt }}">{{ prediction.prompt }}</td>
                        <td class="p-3"><a href="{{ path('prediction_show', {id: prediction.id.value}) }}" class="text-blue-600 hover:text-blue-800">{{ 'action.view'|trans }}</a></td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
