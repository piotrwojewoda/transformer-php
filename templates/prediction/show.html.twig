{% extends 'base.html.twig' %}

{% block title %}{{ 'page.prediction'|trans }} — {{ prediction.id }}{% endblock %}

{% block body %}
    {% if not prediction.isDone() %}
        <meta http-equiv="refresh" content="1">
    {% endif %}

    <h1 class="text-2xl font-bold mb-6">{{ 'page.prediction'|trans }}</h1>

    <div class="bg-white p-6 rounded-lg shadow mb-4">
        <dl class="text-sm space-y-3">
            <div class="flex justify-between items-center py-2 border-b border-gray-100"><dt class="text-gray-600">{{ 'label.status'|trans }}</dt><dd>
                <span class="px-2 py-1 rounded text-xs
                    {{ prediction.status == 'done' ? 'bg-green-100 text-green-800' : '' }}
                    {{ prediction.status == 'failed' ? 'bg-red-100 text-red-800' : '' }}
                    {{ prediction.status in ['queued','running'] ? 'bg-yellow-100 text-yellow-800' : '' }}">
                    {{ prediction.status }}
                </span>
            </dd></div>
            <div class="flex justify-between items-center py-2 border-b border-gray-100"><dt class="text-gray-600">{{ 'label.model'|trans }}</dt><dd><code class="text-xs">{{ prediction.modelId }}</code></dd></div>
            <div class="flex justify-between items-center py-2"><dt class="text-gray-600">{{ 'label.sampling'|trans }}</dt><dd class="text-gray-800">{{ prediction.samplingStrategy }} · max_new_tokens={{ prediction.maxNewTokens }}{{ prediction.topK is not null ? ' · top_k=' ~ prediction.topK }}</dd></div>
        </dl>
    </div>

    <div class="bg-white p-6 rounded-lg shadow mb-4">
        <h2 class="text-sm font-semibold text-gray-700 mb-2">{{ 'label.prompt'|trans }}</h2>
        <pre class="whitespace-pre-wrap break-words text-sm bg-gray-50 p-3 rounded">{{ prediction.prompt }}</pre>
    </div>

    <div class="bg-white p-6 rounded-lg shadow">
        <h2 class="text-sm font-semibold text-gray-700 mb-2">{{ 'label.generated_text'|trans }}</h2>
        {% if prediction.generatedText is not null %}
            <pre class="whitespace-pre-wrap break-words text-sm bg-gray-50 p-3 rounded">{{ prediction.generatedText }}</pre>
        {% elseif prediction.status == 'failed' %}
            <p class="text-red-700 text-sm">{{ 'label.error'|trans }} {{ prediction.errorMessage }}</p>
        {% else %}
            <p class="text-gray-400">{{ 'status.generating'|trans }}</p>
        {% endif %}
    </div>
{% endblock %}
