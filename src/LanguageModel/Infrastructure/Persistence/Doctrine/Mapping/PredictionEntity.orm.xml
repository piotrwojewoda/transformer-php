<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\LanguageModel\Infrastructure\Persistence\Doctrine\Entity\PredictionEntity" table="predictions">
        <id name="id" type="bigint" column="id">
            <generator strategy="IDENTITY"/>
        </id>
        <field name="uuid" type="string" length="36" unique="true"/>
        <field name="modelId" type="integer" column="model_id"/>
        <field name="prompt" type="string" length="500"/>
        <field name="generatedText" type="string" length="500" column="generated_text" nullable="true"/>
        <field name="sampling" type="string" length="8"/>
        <field name="topK" type="smallint" column="top_k" nullable="true"/>
        <field name="maxNewTokens" type="smallint" column="max_new_tokens"/>
        <field name="status" type="string" length="16"/>
        <field name="errorMessage" type="text" column="error_message" nullable="true"/>
        <field name="createdAt" type="datetime_immutable" column="created_at"/>
        <field name="finishedAt" type="datetime_immutable" column="finished_at" nullable="true"/>
    </entity>
</doctrine-mapping>
