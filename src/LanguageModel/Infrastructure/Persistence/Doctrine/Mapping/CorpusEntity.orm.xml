<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\LanguageModel\Infrastructure\Persistence\Doctrine\Entity\CorpusEntity" table="corpora">
        <id name="id" type="bigint" column="id">
            <generator strategy="IDENTITY"/>
        </id>
        <field name="uuid" type="string" length="36" unique="true"/>
        <field name="name" type="string" length="120"/>
        <field name="rawText" type="text" column="raw_text"/>
        <field name="categoryUuid" type="string" column="category_uuid" length="36" nullable="true"/>
        <field name="createdAt" type="datetime_immutable" column="created_at"/>
    </entity>
</doctrine-mapping>
